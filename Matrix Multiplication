#include <iostream>
using namespace std;

void input(int a[][10], int r, int c) {
    for(int i = 0; i < r; i++)
        for(int j = 0; j < c; j++)
            cin >> a[i][j];
}

void multiply(int a[][10], int b[][10], int c[][10], int r1, int c1, int c2) {
    for(int i = 0; i < r1; i++) {
        for(int j = 0; j < c2; j++) {
            c[i][j] = 0;
            for(int k = 0; k < c1; k++)
                c[i][j] += a[i][k] * b[k][j];
        }
    }
}

void display(int c[][10], int r, int col) {
    for(int i = 0; i < r; i++) {
        for(int j = 0; j < col; j++)
            cout << c[i][j] << " ";
        cout << endl;
    }
}

int main() {
    int a[10][10], b[10][10], c[10][10];
    int r1, c1, r2, c2;

    cin >> r1 >> c1;
    cin >> r2 >> c2;

    if(c1 != r2) {
        cout << "Multiplication not possible";
        return 0;
    }

    input(a, r1, c1);
    input(b, r2, c2);

    multiply(a, b, c, r1, c1, c2);
    display(c, r1, c2);

    return 0;
}
